{
  "name": "rejadx",
  "displayName": "ReJadx",
  "description": "Android reverse engineering powered by jadx",
  "version": "0.0.1",
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Other"],
  "activationEvents": ["onStartupFinished"],
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": {
      "title": "ReJadx",
      "properties": {
        "rejadx.search.maxResults": {
          "type": "number",
          "default": 50,
          "minimum": 1,
          "maximum": 5000,
          "description": "Maximum number of matches returned by ReJadx code search."
        },
        "rejadx.customJadxArgs": {
          "type": "string",
          "default": "",
          "description": "Custom Jadx CLI-style arguments passed to ReJadx server on project load (for example: --threads-count=4 --decompilation-mode=simple). Restart server to apply changes."
        }
      }
    },
    "languages": [
      {
        "id": "java",
        "extensions": [".java"]
      },
      {
        "id": "smali",
        "extensions": [".smali"]
      }
    ],
    "grammars": [
      {
        "language": "smali",
        "scopeName": "source.smali",
        "path": "./syntaxes/smali.tmlanguage"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "rejadx",
          "title": "ReJadx",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "rejadx": [
        {
          "type": "webview",
          "id": "rejadx.dashboard",
          "name": "Dashboard"
        },
        {
          "id": "rejadx.classes",
          "name": "Classes"
        }
      ]
    },
    "commands": [
      {
        "command": "jadx.addComment",
        "title": "ReJadx: Add Comment"
      },
      {
        "command": "rejadx.renameAtCursor",
        "title": "ReJadx: Rename Symbol"
      },
      {
        "command": "jadx.openSideBySide",
        "title": "ReJadx: Open Java & Smali Side-by-Side"
      },
      {
        "command": "jadx.exportProGuard",
        "title": "ReJadx: Export ProGuard Mappings"
      },
      {
        "command": "jadx.searchCode",
        "title": "ReJadx: Search in Decompiled Code"
      }
    ],
    "keybindings": [
      {
        "command": "jadx.addComment",
        "key": "ctrl+shift+c",
        "when": "editorTextFocus && resourceScheme == 'jadx'"
      },
      {
        "command": "rejadx.renameAtCursor",
        "key": "f2",
        "when": "editorTextFocus && resourceScheme == 'jadx'"
      },
      {
        "command": "jadx.searchCode",
        "key": "ctrl+shift+f",
        "when": "resourceScheme == 'jadx'"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "lint": "eslint src"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4",
    "ts-loader": "^9.5.1"
  }
}
